{
  "name": "sphere-core",
  "version": "0.0.0",
  "description": "Sphere core protocol schemas, TypeScript packages, and reference node.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spherekeeper/sphere-core.git"
  },
  "homepage": "https://github.com/spherekeeper/sphere-core#readme",
  "bugs": {
    "url": "https://github.com/spherekeeper/sphere-core/issues"
  },
  "keywords": [
    "sphere",
    "event-sourcing",
    "graph",
    "protocol",
    "typescript",
    "reference-node"
  ],
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "pnpm -r --if-present typecheck && tsc -p tsconfig.json --noEmit",
    "lint": "pnpm typecheck"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "typescript": "^5.4.5",
    "vitest": "^3.2.6"
  },
  "license": "MIT"
}
