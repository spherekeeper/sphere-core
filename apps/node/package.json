{
  "name": "@sphere/node",
  "version": "0.0.0",
  "description": "Minimal local reference node for Sphere core experiments.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spherekeeper/sphere-core.git",
    "directory": "apps/node"
  },
  "homepage": "https://github.com/spherekeeper/sphere-core/tree/main/apps/node#readme",
  "bugs": {
    "url": "https://github.com/spherekeeper/sphere-core/issues"
  },
  "keywords": [
    "sphere",
    "event-sourcing",
    "graph",
    "protocol",
    "node",
    "runtime",
    "fastify"
  ],
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "sphere-node": "./src/cli.ts"
  },
  "scripts": {
    "start": "tsx src/cli.ts",
    "test": "cd ../.. && vitest run apps/node/test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sphere/commands": "workspace:*",
    "@sphere/event-store": "workspace:*",
    "@sphere/events": "workspace:*",
    "@sphere/graph": "workspace:*",
    "@sphere/schemas": "workspace:*",
    "@sphere/types": "workspace:*",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "tsx": "^4.22.3"
  },
  "license": "MIT"
}
