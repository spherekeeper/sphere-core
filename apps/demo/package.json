  },
  "keywords": [
    "sphere",
    "event-sourcing",
    "graph",
    "protocol",
    "demo",
    "cli"
  ],
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
